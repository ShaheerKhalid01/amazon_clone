{
  "name": "amazon-clone",
  "version": "1.0.0",
  "private": true,
  "description": "Full-featured Amazon Clone with NestJS and React",
  "author": "Amazon Clone Team",
  "license": "MIT",
  "scripts": {
    "setup": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently -n \"API,WEB\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run start:dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start:prod": "cd backend && npm run start:prod",
    "lint": "cd backend && npm run lint && cd ../frontend && npm run lint",
    "test": "cd backend && npm run test && cd ../frontend && npm run test",
    "test:backend": "cd backend && npm run test",
    "test:frontend": "cd frontend && npm run test",
    "test:e2e": "cd backend && npm run test:e2e",
    "clean": "rimraf backend/node_modules frontend/node_modules node_modules",
    "reinstall": "npm run clean && npm run setup",
    "seed": "cd backend && npm run seed",
    "migrate": "cd backend && npm run migration:run",
    "docker:dev": "docker-compose up -d",
    "docker:build": "docker-compose build",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v && docker system prune -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}